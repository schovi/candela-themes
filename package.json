{
  "name": "candela-themes-tooling",
  "version": "0.1.0",
  "private": true,
  "description": "Build and packaging tooling for the Candela light themes. The generator itself (scripts/generate.js) has zero runtime dependencies.",
  "license": "MIT",
  "scripts": {
    "build": "node scripts/generate.js",
    "validate": "node scripts/validate.js",
    "package:bundles": "node scripts/package-bundles.js",
    "package:intellij": "node scripts/package-intellij.js",
    "package:nvim": "node scripts/package-nvim.js",
    "package:sublime": "node scripts/package-sublime.js",
    "package:zed": "node scripts/package-zed.js",
    "package:vscode": "node scripts/package-vscode.js",
    "app": "cd app && npm run dev",
    "app:screenshots": "cd app && npm run screenshots"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.0"
  }
}
