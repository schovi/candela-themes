<?xml version="1.0" encoding="UTF-8"?>
<idea-plugin>
  <id>com.aurora.themes</id>
  <name>Aurora Light Themes</name>
  <version>0.1.0</version>
  <vendor>Aurora</vendor>
  <description><![CDATA[14 light color themes for tired eyes — low-glare, low-saturation, AAA body contrast.]]></description>
  <idea-version since-build="223" />
  <depends>com.intellij.modules.platform</depends>
  <extensions defaultExtensionNs="com.intellij">
    <themeProvider id="aurora-sepia-paper" path="/themes/aurora-sepia-paper.theme.json" />
    <themeProvider id="aurora-slate-mist" path="/themes/aurora-slate-mist.theme.json" />
    <themeProvider id="aurora-sage" path="/themes/aurora-sage.theme.json" />
    <themeProvider id="aurora-solarized-lite" path="/themes/aurora-solarized-lite.theme.json" />
    <themeProvider id="aurora-blossom" path="/themes/aurora-blossom.theme.json" />
    <themeProvider id="aurora-lagoon" path="/themes/aurora-lagoon.theme.json" />
    <themeProvider id="aurora-meadow" path="/themes/aurora-meadow.theme.json" />
    <themeProvider id="aurora-apricot" path="/themes/aurora-apricot.theme.json" />
    <themeProvider id="aurora-periwinkle" path="/themes/aurora-periwinkle.theme.json" />
    <themeProvider id="aurora-ink-coral" path="/themes/aurora-ink-coral.theme.json" />
    <themeProvider id="aurora-graphite-mono" path="/themes/aurora-graphite-mono.theme.json" />
    <themeProvider id="aurora-tungsten" path="/themes/aurora-tungsten.theme.json" />
    <themeProvider id="aurora-eink-slate" path="/themes/aurora-eink-slate.theme.json" />
    <themeProvider id="aurora-contrast-max" path="/themes/aurora-contrast-max.theme.json" />
  </extensions>
</idea-plugin>
