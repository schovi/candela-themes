  "tokenColors": [
    {
      "scope": [
        "keyword",
        "storage"
      ],
      "settings": {
        "foreground": "#7a1f6b"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#1f6b3a"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#123a7a"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#8a3a12"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#5a2f8a"
      }
    },
    {
      "scope": [
        "support",
        "variable.language",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#0f5f6b"
      }
    },
    {
      "scope": [
        "punctuation",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#565d64"
      }
    },
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#7c838a",
        "fontStyle": "italic"
      }
    }
  ]
}
