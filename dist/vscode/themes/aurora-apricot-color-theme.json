  "tokenColors": [
    {
      "scope": [
        "keyword",
        "storage"
      ],
      "settings": {
        "foreground": "#c85f22"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#6f7a2f"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#3f6fa8"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#b03e6a"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#7a5aa8"
      }
    },
    {
      "scope": [
        "support",
        "variable.language",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#2f8a80"
      }
    },
    {
      "scope": [
        "punctuation",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#7c6c5a"
      }
    },
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#bfa588",
        "fontStyle": "italic"
      }
    }
  ]
}
