  "tokenColors": [
    {
      "scope": [
        "keyword",
        "storage"
      ],
      "settings": {
        "foreground": "#16467a"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#2f7d5a"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#b0402f"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#a85a1f"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#6b3fa0"
      }
    },
    {
      "scope": [
        "support",
        "variable.language",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#0f7d8a"
      }
    },
    {
      "scope": [
        "punctuation",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#5c666e"
      }
    },
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#8b959c",
        "fontStyle": "italic"
      }
    }
  ]
}
