  "tokenColors": [
    {
      "scope": [
        "keyword",
        "storage"
      ],
      "settings": {
        "foreground": "#5a4fc0"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#3f76a0"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#7a3fb0"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#c05a7a"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#2f8a86"
      }
    },
    {
      "scope": [
        "support",
        "variable.language",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#b06a2f"
      }
    },
    {
      "scope": [
        "punctuation",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#6a6c80"
      }
    },
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#9698b6",
        "fontStyle": "italic"
      }
    }
  ]
}
