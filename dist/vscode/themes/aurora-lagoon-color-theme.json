  "tokenColors": [
    {
      "scope": [
        "keyword",
        "storage"
      ],
      "settings": {
        "foreground": "#0f7d99"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#3f8a5a"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#2f6fb0"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#c05a55"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#7a5aa8"
      }
    },
    {
      "scope": [
        "support",
        "variable.language",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#b06a2f"
      }
    },
    {
      "scope": [
        "punctuation",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#5f717a"
      }
    },
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#86a0a6",
        "fontStyle": "italic"
      }
    }
  ]
}
