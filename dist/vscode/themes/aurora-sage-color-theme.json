  "tokenColors": [
    {
      "scope": [
        "keyword",
        "storage"
      ],
      "settings": {
        "foreground": "#b0602f"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#3f6d93"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#2f7d6b"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#8a6a2f"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#6b5aa0"
      }
    },
    {
      "scope": [
        "support",
        "variable.language",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#a15466"
      }
    },
    {
      "scope": [
        "punctuation",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#6a7062"
      }
    },
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#8f9985",
        "fontStyle": "italic"
      }
    }
  ]
}
