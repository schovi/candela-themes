    "terminal.ansiBrightBlack": "#4b5157",
    "terminal.ansiRed": "#55606a",
    "terminal.ansiBrightRed": "#8a3a3a",
    "terminal.ansiGreen": "#3a6ea5",
    "terminal.ansiBrightGreen": "#3a6ea5",
    "terminal.ansiYellow": "#2f4a63",
    "terminal.ansiBrightYellow": "#6a5a2f",
    "terminal.ansiBlue": "#3a4650",
    "terminal.ansiBrightBlue": "#3a4650",
    "terminal.ansiMagenta": "#2f3a44",
    "terminal.ansiBrightMagenta": "#2f3a44",
    "terminal.ansiCyan": "#3a6ea5",
    "terminal.ansiBrightCyan": "#3a6ea5",
    "terminal.ansiWhite": "#949a9f",
    "terminal.ansiBrightWhite": "#f8f9fa"
  },
  "tokenColors": [
    {
      "scope": [
        "keyword",
        "storage"
      ],
      "settings": {
        "foreground": "#2f4a63"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#3a6ea5"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#3a4650"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#55606a"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#2f3a44"
      }
    },
    {
      "scope": [
        "support",
        "variable.language",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#3a6ea5"
      }
    },
    {
      "scope": [
        "punctuation",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#7b838a"
      }
    },
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#949a9f",
        "fontStyle": "italic"
      }
    }
  ]
}
