  "tokenColors": [
    {
      "scope": [
        "keyword",
        "storage"
      ],
      "settings": {
        "foreground": "#3d4d4a"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#4a5a4a"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#3d4a5a"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#5a4d45"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#4d445a"
      }
    },
    {
      "scope": [
        "support",
        "variable.language",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#455a55"
      }
    },
    {
      "scope": [
        "punctuation",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#7b7f80"
      }
    },
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#8c9092",
        "fontStyle": "italic"
      }
    }
  ]
}
