{
  "name": "Aurora 10 · Ink & Coral",
  "author": "Aurora",
  "variables": {
    "bg": "#eef0f0",
    "surface": "#f8fafa",
    "border": "#d8dede",
    "ink": "#222831",
    "ink2": "#4c545d",
    "faint": "#8b959c",
    "selection": "#dbe3e3",
    "cursor": "#222831",
    "lineHighlight": "#e9eded",
    "kw": "#16467a",
    "str": "#2f7d5a",
    "fn": "#b0402f",
    "num": "#a85a1f",
    "type": "#6b3fa0",
    "builtin": "#0f7d8a",
    "punct": "#5c666e",
    "error": "#b0402f",
    "warning": "#a85a1f",
    "ok": "#2f7d5a"
  },
  "globals": {
    "background": "var(surface)",
    "foreground": "var(ink)",
    "caret": "var(cursor)",
    "line_highlight": "var(lineHighlight)",
    "selection": "var(selection)",
    "gutter": "var(bg)",
    "gutter_foreground": "var(ink2)",
    "invisibles": "var(faint)"
  },
  "rules": [
    {
      "scope": "keyword, storage",
      "foreground": "var(kw)"
    },
    {
      "scope": "string",
      "foreground": "var(str)"
    },
    {
      "scope": "entity.name.function, support.function",
      "foreground": "var(fn)"
    },
    {
      "scope": "constant.numeric, constant.language",
      "foreground": "var(num)"
    },
    {
      "scope": "entity.name.type, entity.name.class, support.type",
      "foreground": "var(type)"
    },
    {
      "scope": "support, variable.language, constant.other.symbol",
      "foreground": "var(builtin)"
    },
    {
      "scope": "punctuation, keyword.operator",
      "foreground": "var(punct)"
    },
    {
      "scope": "comment",
      "foreground": "var(faint)",
      "font_style": "italic"
    }
  ]
}
