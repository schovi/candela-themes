{
  "name": "Aurora 03 · Sage",
  "author": "Aurora",
  "variables": {
    "bg": "#edf1e9",
    "surface": "#f6f9f2",
    "border": "#d9dfd0",
    "ink": "#2c322a",
    "ink2": "#565d51",
    "faint": "#8f9985",
    "selection": "#dde6cf",
    "cursor": "#2c322a",
    "lineHighlight": "#f0f4ea",
    "kw": "#b0602f",
    "str": "#3f6d93",
    "fn": "#2f7d6b",
    "num": "#8a6a2f",
    "type": "#6b5aa0",
    "builtin": "#a15466",
    "punct": "#6a7062",
    "error": "#a1465a",
    "warning": "#8a6a2f",
    "ok": "#3f6d93"
  },
  "globals": {
    "background": "var(surface)",
    "foreground": "var(ink)",
    "caret": "var(cursor)",
    "line_highlight": "var(lineHighlight)",
    "selection": "var(selection)",
    "gutter": "var(bg)",
    "gutter_foreground": "var(ink2)",
    "invisibles": "var(faint)"
  },
  "rules": [
    {
      "scope": "keyword, storage",
      "foreground": "var(kw)"
    },
    {
      "scope": "string",
      "foreground": "var(str)"
    },
    {
      "scope": "entity.name.function, support.function",
      "foreground": "var(fn)"
    },
    {
      "scope": "constant.numeric, constant.language",
      "foreground": "var(num)"
    },
    {
      "scope": "entity.name.type, entity.name.class, support.type",
      "foreground": "var(type)"
    },
    {
      "scope": "support, variable.language, constant.other.symbol",
      "foreground": "var(builtin)"
    },
    {
      "scope": "punctuation, keyword.operator",
      "foreground": "var(punct)"
    },
    {
      "scope": "comment",
      "foreground": "var(faint)",
      "font_style": "italic"
    }
  ]
}
