{
  "$schema": "aurora-light-themes/v1",
  "description": "Canonical color source for the Aurora light themes. Every theme defines the same token set so it can be compiled to VS Code, iTerm2, Alacritty, Windows Terminal, Kitty, etc. All backgrounds avoid pure white and all inks avoid pure black; body ink clears WCAG AAA (~7:1+) against its surface.",
  "tokenReference": {
    "ui": {
      "bg": "editor / terminal background",
      "surface": "panels, cards, code area (slightly lighter than bg)",
      "border": "dividers, borders, inactive UI",
      "ink": "primary text / default foreground",
      "ink2": "secondary text, line numbers, punctuation-adjacent",
      "faint": "comments, disabled text, placeholder",
      "selection": "selection background",
      "cursor": "caret color",
      "lineHighlight": "active line background"
    },
    "syntax": {
      "kw": "keywords, storage (class/def/fun/val)",
      "str": "strings, char literals",
      "fn": "function / method names, links",
      "num": "numbers, constants, modified-marker",
      "type": "types, classes, namespaces",
      "builtin": "built-ins, symbols, inline code, cyan/accent role",
      "punct": "punctuation, operators, brackets"
    },
    "diagnostics": {
      "error": "errors / deletions",
      "warning": "warnings",
      "ok": "success / additions (usually = str)"
    }
  },
