  "ansiMapping": {
    "note": "Suggested 16-color terminal mapping derived from each theme's tokens. background=colors.bg, foreground=colors.ink, cursor=colors.cursor, selectionBackground=colors.selection.",
    "normal": {
      "black": "ink",
      "red": "num",
      "green": "str",
      "yellow": "kw",
      "blue": "fn",
      "magenta": "type",
      "cyan": "builtin",
      "white": "faint"
    },
    "bright": {
      "black": "ink2",
      "red": "error",
      "green": "ok",
      "yellow": "warning",
      "blue": "fn",
      "magenta": "type",
      "cyan": "builtin",
      "white": "surface"
    }
  }
