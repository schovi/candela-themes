{
  "name": "candela-themes-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local Vite app that previews every Candela theme and drives automated gallery screenshots. Not published; run with npm run dev.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/prerender.mjs",
    "preview": "vite preview",
    "test": "node --experimental-strip-types --test src/ruleMessages.test.ts",
    "screenshots": "node ../scripts/screenshots.mjs"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.4",
    "playwright": "^1.49.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
